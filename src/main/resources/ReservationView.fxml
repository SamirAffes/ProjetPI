<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ReservationController"
      stylesheets="@css/styles.css">
    
    <!-- Left Sidebar Navigation -->
    <left>
        <VBox styleClass="sidebar">
            <!-- Logo and Brand -->
            <HBox styleClass="logo-container" alignment="CENTER">
                <Label styleClass="logo-text" text="TMS" />
            </HBox>
            
            <!-- Navigation Menu -->
            <VBox styleClass="nav-menu" spacing="8">
                <Button styleClass="nav-button" text="Accueil" onAction="#navigateTo">
                    <graphic>
                        <ImageView fitWidth="24" fitHeight="24" preserveRatio="true" smooth="true">
                            <Image url="@icons/home.png" />
                        </ImageView>
                    </graphic>
                    <VBox.margin>
                        <Insets bottom="4" />
                    </VBox.margin>
                </Button>
                
                <Button styleClass="nav-button" text="Trajets" onAction="#navigateTo">
                    <graphic>
                        <ImageView fitWidth="24" fitHeight="24" preserveRatio="true" smooth="true">
                            <Image url="@icons/route.png" />
                        </ImageView>
                    </graphic>
                    <VBox.margin>
                        <Insets bottom="4" />
                    </VBox.margin>
                </Button>
                
                <Button styleClass="nav-button" text="Transports" onAction="#navigateTo">
                    <graphic>
                        <ImageView fitWidth="24" fitHeight="24" preserveRatio="true" smooth="true">
                            <Image url="@icons/transport.png" />
                        </ImageView>
                    </graphic>
                    <VBox.margin>
                        <Insets bottom="4" />
                    </VBox.margin>
                </Button>
                
                <Button styleClass="nav-button, nav-button-active" text="Réservations">
                    <graphic>
                        <ImageView fitWidth="24" fitHeight="24" preserveRatio="true" smooth="true">
                            <Image url="@icons/reservation.png" />
                        </ImageView>
                    </graphic>
                    <VBox.margin>
                        <Insets bottom="4" />
                    </VBox.margin>
                </Button>
                
                <Button styleClass="nav-button" text="Utilisateurs" onAction="#navigateTo">
                    <graphic>
                        <ImageView fitWidth="24" fitHeight="24" preserveRatio="true" smooth="true">
                            <Image url="@icons/user.png" />
                        </ImageView>
                    </graphic>
                    <VBox.margin>
                        <Insets bottom="4" />
                    </VBox.margin>
                </Button>
            </VBox>
            
            <!-- Footer -->
            <Region VBox.vgrow="ALWAYS" />
            <HBox styleClass="sidebar-footer" alignment="CENTER">
                <Text styleClass="footer-text" text="TunTransport © 2025" />
            </HBox>
        </VBox>
    </left>
    
    <!-- Main Content Area -->
    <center>
        <VBox styleClass="main-area" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <!-- Header with title and user info -->
            <HBox styleClass="top-header">
                <Label styleClass="page-title" text="Gestion des Réservations | إدارة الحجوزات" />
                <Region HBox.hgrow="ALWAYS" />
                <Label styleClass="user-info" text="Med Amine" />
            </HBox>
            
            <!-- Reservations Content -->
            <VBox styleClass="dashboard-content" VBox.vgrow="ALWAYS" prefWidth="Infinity" maxWidth="Infinity">
                <!-- Key Metrics -->
                <HBox spacing="20" styleClass="stats-container">
                    <!-- Total Reservations -->
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="Réservations Totales" />
                        <Label fx:id="totalReservationsLabel" styleClass="stat-value" text="13" />
                    </VBox>
                    
                    <!-- Average Cost -->
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="Coût Moyen" />
                        <Label fx:id="averageCostLabel" styleClass="stat-value" text="27.85 DT" />
                    </VBox>
                    
                    <!-- Completion Rate -->
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="Taux d'Achèvement" />
                        <Label fx:id="completionRateLabel" styleClass="stat-value" text="0.0%" />
                    </VBox>
                </HBox>
                
                <!-- Filter and Actions Bar -->
                <HBox styleClass="action-bar" spacing="15">
                    <HBox spacing="10" styleClass="filter-container" alignment="CENTER_LEFT">
                        <Label text="Filtrer par statut:" />
                        <ComboBox fx:id="statusFilterComboBox" prefWidth="150" />
                    </HBox>
                    
                    <Region HBox.hgrow="ALWAYS" />
                    
                    <Button fx:id="backButton" text="Retour" styleClass="action-button" onAction="#handleBackToHome">
                        <graphic>
                            <ImageView fitWidth="18" fitHeight="18" preserveRatio="true" smooth="true">
                                <Image url="@icons/back.png" />
                            </ImageView>
                        </graphic>
                        <HBox.margin>
                            <Insets right="10" />
                        </HBox.margin>
                    </Button>
                    
                    <Button fx:id="refreshButton" text="Actualiser" styleClass="action-button" onAction="#handleRefresh">
                        <graphic>
                            <ImageView fitWidth="18" fitHeight="18" preserveRatio="true" smooth="true">
                                <Image url="@icons/refresh.png" />
                            </ImageView>
                        </graphic>
                        <HBox.margin>
                            <Insets right="10" />
                        </HBox.margin>
                    </Button>
                    
                    <Button fx:id="addNewReservationButton" text="Ajouter une Réservation" styleClass="action-button">
                        <graphic>
                            <ImageView fitWidth="18" fitHeight="18" preserveRatio="true" smooth="true">
                                <Image url="@icons/add.png" />
                            </ImageView>
                        </graphic>
                    </Button>
                </HBox>
                
                <!-- Reservations Table with improved column widths and alignment -->
                <VBox styleClass="table-container" VBox.vgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">
                    <TableView fx:id="reservationsTable" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" 
                               styleClass="modern-table, reservations-table" 
                               prefWidth="Infinity" maxWidth="Infinity">
                        <columns>
                            <TableColumn fx:id="idColumn" text="ID" prefWidth="50" minWidth="40" maxWidth="60" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="routeColumn" text="Trajet" prefWidth="180" minWidth="150" />
                            <TableColumn fx:id="transportColumn" text="Transport" prefWidth="180" minWidth="150" />
                            <TableColumn fx:id="dateTimeColumn" text="Date et Heure" prefWidth="150" minWidth="120" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="statusColumn" text="Statut" prefWidth="120" minWidth="90" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="priceColumn" text="Prix" prefWidth="100" minWidth="80" style="-fx-alignment: CENTER-RIGHT;" />
                            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="300" minWidth="280" style="-fx-alignment: CENTER;" />
                        </columns>
                        <placeholder>
                            <Label text="Aucune réservation trouvée" />
                        </placeholder>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <padding>
                            <Insets top="5" right="5" bottom="5" left="5" />
                        </padding>
                    </TableView>
                </VBox>
                
                <!-- Status Legend -->
                <HBox spacing="15" styleClass="status-legend">
                    <Label text="Statut:" />
                    <HBox spacing="5" alignment="CENTER">
                        <Label styleClass="status-chip, status-pending" text="En attente" />
                    </HBox>
                    <HBox spacing="5" alignment="CENTER">
                        <Label styleClass="status-chip, status-confirmed" text="Confirmé" />
                    </HBox>
                    <HBox spacing="5" alignment="CENTER">
                        <Label styleClass="status-chip, status-completed" text="Terminé" />
                    </HBox>
                    <HBox spacing="5" alignment="CENTER">
                        <Label styleClass="status-chip, status-cancelled" text="Annulé" />
                    </HBox>
                    
                    <Region HBox.hgrow="ALWAYS" />
                    
                    <Label styleClass="footer-info" text="TunTransport © 2025" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane> 