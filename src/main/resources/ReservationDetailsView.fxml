<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="10.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ReservationDetailsController"
      stylesheets="@css/styles.css">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Text styleClass="title" text="Reservation Details" />
    
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints hgrow="NEVER" minWidth="150" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="200" />
        </columnConstraints>
        
        <Label text="Reservation ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <Label fx:id="idLabel" text="--" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        
        <Label text="Route:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <Label fx:id="routeLabel" text="--" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        
        <Label text="Transport:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <Label fx:id="transportLabel" text="--" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        
        <Label text="Date &amp; Time:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <Label fx:id="dateTimeLabel" text="--" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        
        <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="4">
            <Label fx:id="statusLabel" text="--" />
            <ComboBox fx:id="statusComboBox" visible="false" />
        </HBox>
        
        <Label text="Price:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <Label fx:id="priceLabel" text="--" GridPane.columnIndex="1" GridPane.rowIndex="5" />
        
        <Label text="Is Paid:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="6">
            <Label fx:id="isPaidLabel" text="--" />
            <CheckBox fx:id="isPaidCheckBox" visible="false" />
        </HBox>
        
        <Label text="Round Trip:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
        <Label fx:id="roundTripLabel" text="--" GridPane.columnIndex="1" GridPane.rowIndex="7" />
        
        <Label text="Return Date &amp; Time:" GridPane.columnIndex="0" GridPane.rowIndex="8" />
        <Label fx:id="returnDateTimeLabel" text="--" GridPane.columnIndex="1" GridPane.rowIndex="8" />
        
        <Label text="Created At:" GridPane.columnIndex="0" GridPane.rowIndex="9" />
        <Label fx:id="createdAtLabel" text="--" GridPane.columnIndex="1" GridPane.rowIndex="9" />
    </GridPane>
    
    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="editButton" text="Edit Status" onAction="#handleEdit" />
        <Button fx:id="saveButton" text="Save Changes" onAction="#handleSave" visible="false" />
        <Button fx:id="cancelButton" text="Cancel" onAction="#handleCancel" visible="false" />
        <Button fx:id="closeButton" text="Close" onAction="#close" />
    </HBox>
    
</VBox> 