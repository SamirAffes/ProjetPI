<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
    stylesheets="@css/styles.css">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Text styleClass="title" text="Routes Management" />
    
    <TableView fx:id="routesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" />
            <TableColumn fx:id="originColumn" text="Origin" />
            <TableColumn fx:id="destinationColumn" text="Destination" />
            <TableColumn fx:id="priceColumn" text="Price" />
            <TableColumn fx:id="actionsColumn" text="Actions" />
        </columns>
    </TableView>
    
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Add New Route" />
    </HBox>
</VBox> 